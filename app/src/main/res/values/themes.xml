<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AppSiTefSmartPos.Splash" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/brand_background</item>
        <item name="android:statusBarColor">@color/brand_background</item>
        <item name="android:navigationBarColor">@color/brand_background</item>
    </style>

    <style name="Theme.AppSiTefSmartPos" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_primary_container</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_on_secondary</item>
        <item name="colorSecondaryContainer">@color/brand_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/brand_on_secondary_container</item>
        <item name="colorTertiary">@color/brand_tertiary</item>
        <item name="colorOnTertiary">@color/brand_on_tertiary</item>
        <item name="colorSurface">@color/brand_surface</item>
        <item name="android:colorBackground">@color/brand_background</item>
        <item name="colorOnSurface">@color/brand_on_surface</item>
        <item name="colorOutline">@color/brand_outline</item>
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorSurface</item>
    </style>

    <style name="Widget.AppSiTefSmartPos.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="iconPadding">8dp</item>
        <item name="backgroundTint">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <style name="Widget.AppSiTefSmartPos.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">?attr/colorPrimary</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="Widget.AppSiTefSmartPos.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.AppSiTefSmartPos.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>

    <style name="Widget.AppSiTefSmartPos.Button.MainMenu" parent="Widget.AppSiTefSmartPos.Button.Primary">
        <item name="android:minHeight">60dp</item>
        <item name="android:textSize">16sp</item>
        <item name="iconSize">22dp</item>
        <item name="iconPadding">12dp</item>
    </style>

    <style name="Widget.AppSiTefSmartPos.Button.MainMenu.Secondary" parent="Widget.AppSiTefSmartPos.Button.Secondary">
        <item name="android:minHeight">60dp</item>
        <item name="android:textSize">16sp</item>
        <item name="iconSize">22dp</item>
        <item name="iconPadding">12dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="iconTint">?attr/colorPrimary</item>
    </style>
</resources>
