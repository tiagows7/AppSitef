<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="20dp">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarTefTransaction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:title="Transacao TEF"
        app:titleCentered="true" />

    <com.google.android.material.card.MaterialCardView
        style="@style/Widget.AppSiTefSmartPos.Card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:contentPadding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fluxo TEF em andamento"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTefStatus"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_weight="1"
                android:text="Aguardando retorno do CliSiTef..." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelarTef"
                style="@style/Widget.AppSiTefSmartPos.Button.Secondary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cancelar transacao" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
