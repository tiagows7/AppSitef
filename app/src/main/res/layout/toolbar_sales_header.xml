<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="4dp"
    android:paddingEnd="0dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardToolbarTotal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/brand_primary_container"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/brand_primary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_fuel_icon_circle">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_fuel_nozzle"
                    app:tint="@color/brand_primary" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvToolbarTotalCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/brand_on_primary_container"
                    android:textSize="12sp"
                    tools:text="3 abastecimentos selecionados" />

                <TextView
                    android:id="@+id/tvToolbarGrossAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/brand_on_primary_container"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="R$ 556,62"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvToolbarDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/brand_on_primary_container"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="DESCONTO R$ 12,34"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvToolbarTotalAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="@color/brand_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="R$ 544,28" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnToolbarCancelarVenda"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/cancel_sale"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        app:backgroundTint="@color/brand_surface"
        app:icon="@drawable/ic_cancel_sale"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="26dp"
        app:iconTint="@null"
        app:strokeColor="@color/brand_outline"
        app:strokeWidth="1dp" />

</LinearLayout>
